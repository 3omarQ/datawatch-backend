generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "commonjs"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Provider {
  LOCAL
  GOOGLE
  GITHUB
}

enum ExtractorType {
  SMART
  BASIC
}

enum OutputFormat {
  JSON
  MD
  TXT
  CSV
}

enum Role {
  USER
  ADMIN
}

enum UrlStatus {
  ACTIVE
  INACTIVE
}

enum JobStatus {
  ACTIVE
  PAUSED
}

enum ExecutionStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum LogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}

// ─── Auth Models ──────────────────────────────────────────────────────────────

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  name              String
  password          String?
  emailVerified     Boolean  @default(false)
  provider          Provider @default(LOCAL)
  providerAccountId String?
  image             String?
  role              Role     @default(USER)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  verificationCodes VerificationCode[]
  passwordResets    PasswordReset[]
  targetUrls        TargetUrl[]
  notifications     Notification[]

  notifyByEmail Boolean @default(false)

  @@map("users")
}

model VerificationCode {
  id        String   @id @default(uuid())
  code      String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_codes")
}

model PasswordReset {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// ─── Scraping Models ──────────────────────────────────────────────────────────

model TargetUrl {
  id        String    @id @default(uuid())
  url       String
  baseUrl   String?
  name      String
  status    UrlStatus @default(ACTIVE)
  userId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  datapoints Datapoint[]

  @@unique([url, userId])
  @@map("target_urls")
}

model Datapoint {
  id   String @id @default(uuid())
  name String

  path               String
  fieldNames         String?
  paginationSelector String?
  maxPages           Int?

  targetUrlId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  targetUrl TargetUrl @relation(fields: [targetUrlId], references: [id], onDelete: Cascade)
  jobs      Job[]

  @@map("datapoints")
}

model Job {
  id            String    @id @default(uuid())
  status        JobStatus @default(ACTIVE)
  scheduleStart DateTime?
  cron          String?
  datapointId   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  extractorType ExtractorType @default(BASIC)
  outputFormat  OutputFormat  @default(JSON)

  webhookUrl String?

  notifyOnFinish Boolean @default(true)
  notifyOnDiff   Boolean @default(true)
  notifyOnFail   Boolean @default(true)

  datapoint  Datapoint      @relation(fields: [datapointId], references: [id], onDelete: Cascade)
  executions JobExecution[]

  @@map("jobs")
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  jobId       String?
  executionId String?
  type        NotificationType
  title       String
  body        String
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  EXECUTION_DONE
  EXECUTION_FAILED
  EXECUTION_DIFF
}

model JobExecution {
  id         String          @id @default(uuid())
  status     ExecutionStatus @default(PENDING)
  startedAt  DateTime?
  finishedAt DateTime?
  jobId      String
  createdAt  DateTime        @default(now())

  job     Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  logs    Log[]
  results Result[]

  @@map("job_executions")
}

model Log {
  id          String   @id @default(uuid())
  level       LogLevel
  message     String
  date        DateTime @default(now())
  executionId String

  execution JobExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@map("logs")
}

model Result {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  definition  Json
  executionId String

  execution JobExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@map("results")
}
